<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer gradient ring -->
    <item>
        <shape android:shape="oval">
            <size android:width="140dp" android:height="140dp" />
            <solid android:color="#00FFFFFF" />
            <stroke android:width="6dp" android:color="#FFE5B3" />
        </shape>
    </item>

    <!-- Inner white circle (avatar background) -->
    <item android:left="6dp" android:top="6dp" android:right="6dp" android:bottom="6dp">
        <shape android:shape="oval">
            <solid android:color="#FFFFFFFF" />
        </shape>
    </item>

</layer-list>
