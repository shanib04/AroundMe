<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base rounded gradient -->
    <item>
        <shape android:shape="rectangle">
            <!-- Stronger green gradient -->
            <gradient
                android:startColor="#FF43A047"
                android:endColor="#FFB9F6CA"
                android:angle="0" />
            <corners android:radius="16dp" />
        </shape>
    </item>

    <!-- Soft overlay highlight at top-right -->
    <item android:top="0dp" android:right="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#60FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="45" />
            <corners android:radius="16dp" />
        </shape>
    </item>

    <!-- Soft radial glow centered-right to amplify highlight -->
    <item>
        <shape android:shape="rectangle">
            <size android:width="0dp" android:height="0dp" />
        </shape>
    </item>

</layer-list>
