<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base rounded gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FFECB35C"
                android:endColor="#FFF9D976"
                android:angle="0" />
            <corners android:radius="16dp" />
        </shape>
    </item>

    <!-- Soft overlay highlight at top-right -->
    <item android:top="0dp" android:right="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#40FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="45" />
            <corners android:radius="16dp" />
        </shape>
    </item>

</layer-list>
