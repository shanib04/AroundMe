<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.colman.aroundme.features.auth.login.LoginFragment"
        android:label="Login">
        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_loginFragment_to_feedFragment"
            app:destination="@id/feedFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.colman.aroundme.features.auth.register.RegisterFragment"
        android:label="Register">
        <action
            android:id="@+id/action_registerFragment_to_feedFragment"
            app:destination="@id/feedFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_registerFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/registerFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/feedFragment"
        android:name="com.colman.aroundme.features.feed.FeedFragment"
        android:label="Feed">
        <action
            android:id="@+id/action_feedFragment_to_eventDetailsFragment"
            app:destination="@id/eventDetailsFragment" />
    </fragment>

    <fragment
        android:id="@+id/mapFragment"
        android:name="com.colman.aroundme.features.map.MapFragment"
        android:label="Map">
        <action
            android:id="@+id/action_mapFragment_to_eventDetailsFragment"
            app:destination="@id/eventDetailsFragment" />
    </fragment>

    <fragment
        android:id="@+id/eventDetailsFragment"
        android:name="com.colman.aroundme.features.event.EventDetailsFragment"
        android:label="Event Details">
        <argument
            android:name="eventId"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/createEventFragment"
        android:name="com.colman.aroundme.features.create.CreateEventFragment"
        android:label="Create Event">
        <action
            android:id="@+id/action_createEventFragment_to_locationPickerFragment"
            app:destination="@id/locationPickerFragment" />
    </fragment>

    <fragment
        android:id="@+id/locationPickerFragment"
        android:name="com.colman.aroundme.features.create.LocationPickerFragment"
        android:label="Pick Location" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.colman.aroundme.features.profile.ProfileFragment"
        android:label="Profile">
        <action
            android:id="@+id/action_profileFragment_to_editProfileFragment"
            app:destination="@id/editProfileFragment" />
    </fragment>

    <fragment
        android:id="@+id/editProfileFragment"
        android:name="com.colman.aroundme.features.profile.EditProfileFragment"
        android:label="Edit Profile" />

    <fragment
        android:id="@+id/myEventsFragment"
        android:name="com.colman.aroundme.features.feed.FeedFragment"
        android:label="My Events" />

</navigation>
