<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="18dp"
    android:layout_marginTop="18dp"
    android:layout_marginBottom="20dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="28dp"
    app:cardElevation="10dp"
    app:strokeColor="#F0F0F0"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Title + details (keep it lightweight so it matches premium feel) -->
        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/text_dark"
            android:textSize="22sp"
            android:textStyle="bold"
            tools:text="Night Market &amp; Street Food" />

        <TextView
            android:id="@+id/txtLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_light"
            android:textSize="13sp"
            tools:text="Central Park, New York" />

        <TextView
            android:id="@+id/txtVotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/text_light"
            android:textSize="12sp"
            tools:text="42 confirmed • 3 reports" />

        <!-- Vote actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHappening"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Happening"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#2E7D32"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_event_active_check"
                app:iconTint="#2E7D32"
                app:iconPadding="8dp"
                app:strokeWidth="0dp"
                app:backgroundTint="#E8F5E9" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEnded"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Ended"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#C62828"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_event_inactive_flag"
                app:iconTint="#C62828"
                app:iconPadding="8dp"
                app:strokeWidth="0dp"
                app:backgroundTint="#FFEBEE" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
