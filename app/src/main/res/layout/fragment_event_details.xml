<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_event_details_screen"
    tools:context=".EventDetailsFragment">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/closeButton"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="20dp"
        android:contentDescription="@string/event_details_close"
        app:backgroundTint="@android:color/white"
        app:cornerRadius="26dp"
        app:icon="@drawable/ic_close_navy"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconTint="@color/event_details_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeColor="@color/map_panel_stroke"
        app:strokeWidth="1dp" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="20dp"
        android:paddingTop="88dp"
        android:paddingEnd="20dp"
        android:paddingBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#EBFFFFFF"
                app:cardCornerRadius="40dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="240dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/headerImageView"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.AroundMe.ImageLarge"
                            tools:src="@tools:sample/backgrounds/scenic" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="18dp"
                            android:layout_marginTop="18dp"
                            android:background="@drawable/bg_live_check_badge"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="10dp">

                            <View
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:background="@drawable/bg_live_dot" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:text="@string/event_details_live_check"
                                android:textColor="@color/event_positive"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom"
                            android:background="@drawable/bg_event_image_scrim"
                            android:orientation="vertical"
                            android:paddingStart="18dp"
                            android:paddingTop="56dp"
                            android:paddingEnd="18dp"
                            android:paddingBottom="18dp">

                            <TextView
                                android:id="@+id/locationTitleText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@android:color/white"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                tools:text="SoHo Pop-up Market" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:src="@drawable/ic_schedule_white" />

                                <TextView
                                    android:id="@+id/reportedTimeText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:textColor="#E6FFFFFF"
                                    android:textSize="14sp"
                                    tools:text="Reported 20m ago" />
                            </LinearLayout>
                        </LinearLayout>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:paddingHorizontal="18dp"
                        android:paddingTop="26dp"
                        android:paddingBottom="8dp">

                        <FrameLayout
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            android:background="@drawable/bg_question_bubble">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_help_bubble" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/eventTitleText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:text="@string/event_details_title_placeholder"
                            android:textAlignment="center"
                            android:textColor="@color/event_details_title"
                            android:textSize="28sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/helpText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:gravity="center"
                            android:textAlignment="center"
                            android:textColor="@color/event_details_subtitle"
                            android:textSize="18sp"
                            tools:text="Help 240 people know if they should come join the fun!" />

                        <TextView
                            android:id="@+id/eventSubtitleText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:gravity="center"
                            android:textAlignment="center"
                            android:textColor="@color/event_details_subtitle"
                            android:textSize="15sp"
                            tools:text="Street vendors, music, and community energy all in one place." />

                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/tagsChipGroup"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            app:chipSpacingHorizontal="8dp"
                            app:chipSpacingVertical="8dp" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/stillHappeningButton"
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="20dp"
                        android:layout_marginEnd="12dp"
                        android:text="@string/event_details_still_happening"
                        android:textAllCaps="false"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/event_positive"
                        app:cornerRadius="30dp"
                        app:icon="@drawable/ic_check_circle_large"
                        app:iconGravity="textEnd"
                        app:iconPadding="24dp"
                        app:iconTint="@android:color/white" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/endedButton"
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginEnd="12dp"
                        android:layout_marginBottom="12dp"
                        android:text="@string/event_details_ended"
                        android:textAllCaps="false"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/event_negative"
                        app:cornerRadius="30dp"
                        app:icon="@drawable/ic_cancel_large"
                        app:iconGravity="textEnd"
                        app:iconPadding="24dp"
                        app:iconTint="@android:color/white" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@android:color/white"
                android:paddingHorizontal="24dp"
                android:paddingVertical="12dp"
                android:text="@string/event_details_not_here"
                android:textColor="@color/event_details_subtitle"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
