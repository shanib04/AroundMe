<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ds_surface"
    tools:context="com.colman.aroundme.features.event.EventDetailsFragment">

    <!-- Full-width glass top bar (flush to edges) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#B3FFFFFF"
        app:cardCornerRadius="0dp"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/back"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/ds_on_surface_variant"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/screenTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Event Details"
                android:textColor="@color/ds_on_surface"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/backButton"
                app:layout_constraintEnd_toStartOf="@+id/btnShare"
                app:layout_constraintStart_toEndOf="@id/backButton"
                app:layout_constraintTop_toTopOf="@id/backButton" />

            <!-- Top bar share button -->
            <ImageButton
                android:id="@+id/btnShare"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_share"
                app:tint="#5a5c5c"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="120dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero section (edge-to-edge) -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="309dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/heroImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    tools:src="@tools:sample/backgrounds/scenic" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_event_details_hero_scrim" />
            </FrameLayout>

            <!-- Content container with overlap (-48dp) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-48dp"
                android:orientation="vertical"
                android:paddingHorizontal="20dp">

                <!-- Event info card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/eventInfoCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/ds_surface_lowest"
                    app:cardCornerRadius="32dp"
                    app:cardElevation="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <HorizontalScrollView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:overScrollMode="never"
                            android:scrollbars="none">

                            <com.google.android.material.chip.ChipGroup
                                android:id="@+id/tagsChipGroup"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:chipSpacingHorizontal="8dp"
                                app:chipSpacingVertical="8dp" />
                        </HorizontalScrollView>

                        <TextView
                            android:id="@+id/eventTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:textColor="@color/ds_on_surface"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            tools:text="Night Market &amp; Street Food" />

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/timeCard"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            app:cardBackgroundColor="@color/ds_surface_lowest"
                            app:cardCornerRadius="22dp"
                            app:cardElevation="0dp"
                            app:strokeColor="@color/ds_secondary_10"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:paddingHorizontal="14dp"
                                android:paddingVertical="12dp">

                                <FrameLayout
                                    android:layout_width="38dp"
                                    android:layout_height="38dp"
                                    android:background="@drawable/bg_icon_circle_teal">

                                    <ImageView
                                        android:layout_width="20dp"
                                        android:layout_height="20dp"
                                        android:layout_gravity="center"
                                        android:contentDescription="@null"
                                        android:src="@drawable/ic_calendar"
                                        app:tint="@color/ds_secondary" />
                                </FrameLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="12dp"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/eventTimePrimary"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:background="@drawable/bg_event_status_pill"
                                        android:paddingHorizontal="10dp"
                                        android:paddingVertical="4dp"
                                        android:textColor="@color/ds_secondary"
                                        android:textSize="14sp"
                                        android:textStyle="bold"
                                        tools:text="Live now" />

                                    <TextView
                                        android:id="@+id/eventTimeSecondary"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="2dp"
                                        android:textColor="@color/ds_on_surface_variant"
                                        android:textSize="13sp"
                                        tools:text="Posted Sun, Mar 29 at 7:00 PM" />
                                </LinearLayout>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/ratingCard"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            app:cardBackgroundColor="@color/ds_surface_lowest"
                            app:cardCornerRadius="22dp"
                            app:cardElevation="0dp"
                            app:strokeColor="@color/ds_secondary_10"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:baselineAligned="false"
                                android:clipChildren="false"
                                android:clipToPadding="false"
                                android:gravity="center_vertical"
                                android:minHeight="64dp"
                                android:orientation="horizontal"
                                android:paddingStart="14dp"
                                android:paddingTop="12dp"
                                android:paddingEnd="14dp"
                                android:paddingBottom="12dp">

                                <FrameLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center_vertical"
                                    android:clipChildren="false"
                                    android:clipToPadding="false"
                                    android:paddingStart="10dp"
                                    android:paddingEnd="4dp"
                                    android:paddingTop="2dp"
                                    android:paddingBottom="2dp">

                                    <RatingBar
                                        android:id="@+id/ratingBar"
                                        style="?android:attr/ratingBarStyleSmall"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:isIndicator="false"
                                        android:numStars="5"
                                        android:rating="0"
                                        android:stepSize="0.5"
                                        android:progressTint="#FFD700"
                                        android:scaleX="1.16"
                                        android:scaleY="1.16"
                                        android:transformPivotX="0dp"
                                        android:transformPivotY="0dp" />
                                </FrameLayout>

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="16dp"
                                    android:layout_gravity="center_vertical"
                                    android:baselineAligned="false"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal"
                                    android:translationY="1dp">

                                    <TextView
                                        android:id="@+id/ratingValue"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:includeFontPadding="false"
                                        android:textColor="@color/ds_on_surface"
                                        android:textSize="20sp"
                                        android:textStyle="bold"
                                        tools:text="4.5" />

                                    <TextView
                                        android:id="@+id/ratingCount"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:includeFontPadding="false"
                                        android:textColor="@color/ds_on_surface_variant"
                                        android:textSize="12sp"
                                        tools:text="128 reviews" />
                                </LinearLayout>

                                <View
                                    android:layout_width="0dp"
                                    android:layout_height="0dp"
                                    android:layout_weight="1" />

                                <TextView
                                    android:id="@+id/rateHint"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="12dp"
                                    android:background="@drawable/bg_event_status_pill"
                                    android:paddingHorizontal="10dp"
                                    android:paddingVertical="6dp"
                                    android:text="Tap to rate"
                                    android:textColor="@color/ds_secondary"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />

                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Publisher card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/publisherCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="@color/ds_surface_lowest"
                    app:cardCornerRadius="32dp"
                    app:cardElevation="0dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/publisherAvatar"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:scaleType="centerCrop"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:shapeAppearanceOverlay="@style/CircleImageView"
                            android:src="@drawable/ic_person_placeholder"
                            tools:src="@tools:sample/avatars" />

                        <TextView
                            android:id="@+id/publisherName"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textColor="@color/ds_on_surface"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toEndOf="@id/publisherAvatar"
                            app:layout_constraintTop_toTopOf="@id/publisherAvatar"
                            app:layout_constraintEnd_toEndOf="parent"
                            tools:text="Alex Rivera" />

                        <TextView
                            android:id="@+id/publisherHandle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_marginTop="2dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textColor="@color/ds_on_surface_variant"
                            android:textSize="12sp"
                            app:layout_goneMarginTop="0dp"
                            app:layout_constraintStart_toEndOf="@id/publisherAvatar"
                            app:layout_constraintTop_toBottomOf="@id/publisherName"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintBottom_toBottomOf="@id/publisherAvatar"
                            tools:text="@alex_r" />

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Location + Navigate -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="@color/ds_surface_lowest"
                    app:cardCornerRadius="32dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:baselineAligned="false"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <FrameLayout
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_icon_circle_teal">

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:contentDescription="@null"
                                    android:src="@drawable/ic_location_pin"
                                    app:tint="@color/ds_secondary" />
                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/locationName"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/ds_on_surface"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    tools:text="Central Park, New York" />

                                <TextView
                                    android:id="@+id/locationSubtitle"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:textColor="@color/ds_on_surface_variant"
                                    android:textSize="12sp"
                                    tools:text="Entrance at 72nd St &amp; 5th Ave" />
                            </LinearLayout>
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/navigateButton"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginTop="14dp"
                            android:text="Navigate to Event"
                            android:textAllCaps="false"
                            android:textColor="@color/ds_on_primary"
                            android:textStyle="bold"
                            app:cornerRadius="28dp"
                            app:icon="@drawable/ic_near_me"
                            app:iconGravity="textStart"
                            app:iconTint="@color/ds_on_primary"
                            app:iconPadding="10dp"
                            app:backgroundTint="@color/ds_primary" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- About -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="ABOUT EVENT"
                    android:textAllCaps="true"
                    android:textColor="@color/ds_on_surface_variant"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:alpha="0.55" />

                <TextView
                    android:id="@+id/aboutText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textColor="@color/ds_on_surface_variant"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"
                    tools:text="Experience the best local street food, live jazz music, and handmade crafts..." />

                <!-- Community Validation -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    app:cardBackgroundColor="@color/ds_surface_low"
                    app:cardCornerRadius="32dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="Is this still happening?"
                            android:textColor="@color/ds_on_surface"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:baselineAligned="false"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/stillHappeningButton"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="64dp"
                                android:layout_weight="1"
                                android:text="Still Happening!"
                                android:textAllCaps="false"
                                android:textStyle="bold"
                                android:textColor="@color/ds_on_surface_variant"
                                app:backgroundTint="@color/ds_surface_container_high"
                                app:cornerRadius="20dp"
                                app:strokeColor="@color/ds_surface_container_high"
                                app:strokeWidth="2dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/endedButton"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="64dp"
                                android:layout_marginStart="10dp"
                                android:layout_weight="1"
                                android:text="Ended / Inactive"
                                android:textAllCaps="false"
                                android:textStyle="bold"
                                android:textColor="@color/ds_on_surface_variant"
                                app:backgroundTint="@color/ds_surface_container_high"
                                app:cornerRadius="20dp"
                                app:strokeColor="@color/ds_surface_container_high"
                                app:strokeWidth="2dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:baselineAligned="false"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/confirmedText"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:textColor="@color/ds_secondary"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                tools:text="42 confirmed" />

                            <TextView
                                android:id="@+id/reportsText"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:textColor="#b02500"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                tools:text="3 reports" />
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Nearby Essentials -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Nearby Essentials"
                        android:textColor="@color/ds_on_surface"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:overScrollMode="never"
                        android:scrollbars="none">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/filterParking"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:text="Parking"
                                android:textAllCaps="false"
                                android:textStyle="bold"
                                android:textSize="12sp"
                                app:cornerRadius="20dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/filterFood"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:layout_marginStart="10dp"
                                android:text="Food"
                                android:textAllCaps="false"
                                android:textStyle="bold"
                                android:textSize="12sp"
                                app:cornerRadius="20dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/filterGas"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:layout_marginStart="10dp"
                                android:text="Gas Stations"
                                android:textAllCaps="false"
                                android:textStyle="bold"
                                android:textSize="12sp"
                                app:cornerRadius="20dp" />
                        </LinearLayout>
                    </HorizontalScrollView>

                    <ProgressBar
                        android:id="@+id/nearbyLoading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="14dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/nearbyEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:text="No places found"
                        android:textColor="@color/ds_on_surface_variant"
                        android:textSize="13sp"
                        android:visibility="gone" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/nearbyRecycler"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:overScrollMode="never"
                        android:clipToPadding="false"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:paddingBottom="4dp"
                        tools:listitem="@layout/item_nearby_essential" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="24dp" />

            </LinearLayout>
        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
