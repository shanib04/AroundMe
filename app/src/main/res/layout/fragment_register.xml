<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_gradient"
    tools:context=".RegisterFragment">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingTop="24dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/formContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingVertical="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:maxWidth="400dp">

                <TextView
                    android:id="@+id/titleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:text="@string/register_title"
                    android:textColor="@color/register_text_primary"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/subtitleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="4dp"
                    android:text="@string/register_subtitle"
                    android:textColor="@color/register_text_secondary"
                    android:textSize="15sp" />

                <FrameLayout
                    android:id="@+id/profileImageContainer"
                    android:layout_width="148dp"
                    android:layout_height="148dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="20dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/profileImageView"
                        android:layout_width="132dp"
                        android:layout_height="132dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_register_image_placeholder"
                        android:clickable="true"
                        android:contentDescription="@string/profile_picture_content_description"
                        android:focusable="true"
                        android:padding="10dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_person_placeholder"
                        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.AroundMe.ProfileAvatar" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/selectImageButton"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_gravity="bottom|end"
                        android:layout_marginEnd="4dp"
                        android:layout_marginBottom="10dp"
                        android:contentDescription="@string/select_profile_picture"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"
                        android:src="@drawable/ic_camera_alt"
                        app:backgroundTint="@color/register_primary"
                        app:cornerRadius="28dp"
                        app:icon="@drawable/ic_camera_alt"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="20dp"
                        app:iconTint="@android:color/white"
                        app:rippleColor="@color/register_shadow"
                        app:strokeColor="@android:color/white"
                        app:strokeWidth="3dp" />
                </FrameLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/fullNameLayout"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:hint="@string/full_name_label"
                    app:boxBackgroundColor="@android:color/white"
                    app:boxCornerRadiusBottomEnd="22dp"
                    app:boxCornerRadiusBottomStart="22dp"
                    app:boxCornerRadiusTopEnd="22dp"
                    app:boxCornerRadiusTopStart="22dp"
                    app:boxStrokeColor="@color/register_input_stroke"
                    app:boxStrokeErrorColor="@color/register_primary"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:hintTextColor="@color/register_text_primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/fullNameEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:imeOptions="actionNext"
                        android:inputType="textPersonName"
                        android:minHeight="54dp"
                        android:textColor="@color/register_text_primary"
                        android:textColorHint="@color/register_hint" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/emailLayout"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="@string/email_label"
                    app:boxBackgroundColor="@android:color/white"
                    app:boxCornerRadiusBottomEnd="22dp"
                    app:boxCornerRadiusBottomStart="22dp"
                    app:boxCornerRadiusTopEnd="22dp"
                    app:boxCornerRadiusTopStart="22dp"
                    app:boxStrokeColor="@color/register_input_stroke"
                    app:boxStrokeErrorColor="@color/register_primary"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:hintTextColor="@color/register_text_primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/emailEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:imeOptions="actionNext"
                        android:inputType="textEmailAddress"
                        android:minHeight="54dp"
                        android:textColor="@color/register_text_primary"
                        android:textColorHint="@color/register_hint" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/passwordLayout"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="@string/password_hint"
                    app:boxBackgroundColor="@android:color/white"
                    app:boxCornerRadiusBottomEnd="22dp"
                    app:boxCornerRadiusBottomStart="22dp"
                    app:boxCornerRadiusTopEnd="22dp"
                    app:boxCornerRadiusTopStart="22dp"
                    app:boxStrokeColor="@color/register_input_stroke"
                    app:boxStrokeErrorColor="@color/register_primary"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:endIconMode="password_toggle"
                    app:endIconTint="@color/register_hint"
                    app:hintTextColor="@color/register_text_primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/passwordEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:imeOptions="actionNext"
                        android:inputType="textPassword"
                        android:minHeight="54dp"
                        android:textColor="@color/register_text_primary"
                        android:textColorHint="@color/register_hint" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/confirmPasswordLayout"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="@string/confirm_password_label"
                    app:boxBackgroundColor="@android:color/white"
                    app:boxCornerRadiusBottomEnd="22dp"
                    app:boxCornerRadiusBottomStart="22dp"
                    app:boxCornerRadiusTopEnd="22dp"
                    app:boxCornerRadiusTopStart="22dp"
                    app:boxStrokeColor="@color/register_input_stroke"
                    app:boxStrokeErrorColor="@color/register_primary"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:endIconMode="password_toggle"
                    app:endIconTint="@color/register_hint"
                    app:hintTextColor="@color/register_text_primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/confirmPasswordEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:imeOptions="actionDone"
                        android:inputType="textPassword"
                        android:minHeight="54dp"
                        android:textColor="@color/register_text_primary"
                        android:textColorHint="@color/register_hint" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/signUpButton"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="16dp"
                    android:elevation="6dp"
                    android:text="@string/sign_up"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/register_primary"
                    app:cornerRadius="22dp" />

                <LinearLayout
                    android:id="@+id/dividerRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/register_input_stroke" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="10dp"
                        android:text="@string/or"
                        android:textColor="@color/register_hint"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/register_input_stroke" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/googleButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="14dp"
                    android:backgroundTint="@android:color/white"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/continue_with_google"
                    android:textAllCaps="false"
                    android:textColor="@color/register_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:cornerRadius="22dp"
                    app:icon="@drawable/ic_google_logo"
                    app:iconGravity="textStart"
                    app:iconPadding="10dp"
                    app:iconTint="@null"
                    app:strokeColor="@color/register_input_stroke"
                    app:strokeWidth="1dp" />

                <LinearLayout
                    android:id="@+id/signInRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="14dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/alreadyHaveAccountText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/already_have_account"
                        android:textColor="@color/register_text_secondary"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/signInText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:text="@string/sign_in_now"
                        android:textColor="@color/register_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
