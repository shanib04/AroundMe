<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@color/soft_surface"
    tools:context=".features.profile.ProfileFragment">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarProfile"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@color/soft_surface"
        app:titleTextAppearance="@style/TextAppearance.MaterialComponents.Headline6"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:elevation="0dp"
        android:title=""
        app:navigationIcon="@drawable/ic_arrow_back" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/toolbarProfile"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="24dp">

            <!-- Top avatar + badge -->
            <ImageView
                android:id="@+id/profileImageView"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/ic_person_placeholder"
                android:scaleType="centerCrop"
                android:contentDescription="@string/profile_photo_content_description"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="24dp"
                android:background="@drawable/avatar_halo" />

            <!-- small validator badge overlapping avatar -->
            <TextView
                android:id="@+id/validatorBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:background="@drawable/chip_bg_rounded"
                android:text="@string/community_validator_label"
                android:textSize="12sp"
                android:textColor="@color/map_secondary"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/profileImageView"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:visibility="gone" />

            <!-- Name -->
            <TextView
                android:id="@+id/profileNameText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_name_placeholder"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="@color/text_dark"
                app:layout_constraintTop_toBottomOf="@id/profileImageView"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="16dp" />

            <!-- Handle -->
            <TextView
                android:id="@+id/profileHandleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_handle_placeholder"
                android:textSize="14sp"
                android:textColor="@color/text_light"
                app:layout_constraintTop_toBottomOf="@id/profileNameText"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp" />

            <!-- Stats row: two small cards -->
            <LinearLayout
                android:id="@+id/statsRow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/profileHandleText"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="16dp"
                android:weightSum="3">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="12dp"
                    android:layout_marginEnd="8dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/eventsCountText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/zero_text"
                            android:textStyle="bold"
                            android:textSize="20sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/profile_events_label"
                            android:textSize="12sp"
                            android:textColor="@color/text_light" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="12dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/validationsCountText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/zero_text"
                            android:textStyle="bold"
                            android:textSize="20sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/profile_validations_label"
                            android:textSize="12sp"
                            android:textColor="@color/text_light" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="12dp"
                    android:layout_marginStart="8dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/pointsStatText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/zero_text"
                            android:textStyle="bold"
                            android:textSize="20sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/points_word"
                            android:textSize="12sp"
                            android:textColor="@color/text_light" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Placeholder shown when user has no posts -->
            <TextView
                android:id="@+id/noPostsPlaceholder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/profile_no_posts_message"
                android:textAlignment="center"
                android:textSize="16sp"
                android:textColor="@color/text_light"
                android:padding="24dp"
                app:layout_constraintTop_toBottomOf="@id/statsRow"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:visibility="gone" />

            <!-- Points card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/pointsCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:minHeight="200dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="8dp"
                app:layout_constraintTop_toBottomOf="@id/statsRow"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="20dp">

                <!-- Use a FrameLayout so we can place the level pill and badge over the gradient background -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="200dp"
                    android:padding="18dp"
                    android:background="@drawable/bg_points_card_gradient">

                    <!-- Level pill (top-left) -->
                    <TextView
                        android:id="@+id/levelPill"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:paddingLeft="12dp"
                        android:paddingRight="12dp"
                        android:gravity="center_vertical"
                        android:background="@drawable/pill_white_rounded"
                        android:text="@string/level_label"
                        android:textSize="12sp"
                        android:textColor="@color/text_dark"
                        android:layout_gravity="top|end" />

                    <!-- Top-right badge -->
                    <TextView
                        android:id="@+id/topBadge"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:visibility="gone" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_gravity="center"
                        android:gravity="center_vertical"
                        android:paddingTop="36dp"
                        android:paddingBottom="10dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/pointsValueText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/zero_text"
                                android:textSize="36sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_dark" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/points_word"
                                android:textSize="16sp"
                                android:textColor="@color/text_dark"
                                android:layout_marginStart="8dp" />
                        </LinearLayout>

                        <!-- Progress track (custom) -->
                        <FrameLayout
                            android:id="@+id/progressTrack"
                            android:layout_width="match_parent"
                            android:layout_height="16dp"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/points_progress_track"
                            android:padding="2dp">

                            <View
                                android:id="@+id/progressFill"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_gravity="start"
                                android:background="@drawable/points_progress_fill" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="8dp">

                            <TextView
                                android:id="@+id/currentLabel"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/current_label"
                                android:textColor="@color/text_dark"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/progressRightText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/progress_right_text"
                                android:textColor="@color/text_dark"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <!-- New points summary and completion percent labels -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="4dp">

                            <TextView
                                android:id="@+id/pointsSummaryText"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/profile_points_summary_default"
                                android:textColor="@color/text_dark"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/completionPercentText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/profile_completion_default"
                                android:textColor="@color/text_dark"
                                android:textSize="13sp" />
                        </LinearLayout>

                    </LinearLayout>

                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Achievements header and view all action -->
            <LinearLayout
                android:id="@+id/achievementsHeaderRow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/pointsCard">

                <TextView
                    android:id="@+id/achievementsTitleText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/achievements_label"
                    android:textColor="@color/text_dark"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/viewAllAchievementsText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="4dp"
                    android:text="@string/view_all"
                    android:textColor="@color/map_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Achievements preview row: fixed slots -->
            <LinearLayout
                android:id="@+id/achievementsPreviewRow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:weightSum="3"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/achievementsHeaderRow">

                <LinearLayout
                    android:id="@+id/achievementSlotOne"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingHorizontal="4dp"
                    android:paddingVertical="4dp">

                    <TextView
                        android:id="@+id/achievementOneIconText"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/ach_bg_orange"
                        android:gravity="center"
                        android:text="@string/achievement_icon_placeholder"
                        android:textSize="28sp" />

                    <TextView
                        android:id="@+id/achievementOneNameText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:maxLines="2"
                        android:text="@string/achievement_name_placeholder"
                        android:textColor="@color/text_light"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/achievementSlotTwo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingHorizontal="4dp"
                    android:paddingVertical="4dp">

                    <TextView
                        android:id="@+id/achievementTwoIconText"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/ach_bg_blue"
                        android:gravity="center"
                        android:text="@string/achievement_icon_placeholder"
                        android:textSize="28sp" />

                    <TextView
                        android:id="@+id/achievementTwoNameText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:maxLines="2"
                        android:text="@string/achievement_name_placeholder"
                        android:textColor="@color/text_light"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/achievementSlotThree"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingHorizontal="4dp"
                    android:paddingVertical="4dp">

                    <TextView
                        android:id="@+id/achievementThreeIconText"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/ach_bg_purple"
                        android:gravity="center"
                        android:text="@string/achievement_icon_placeholder"
                        android:textSize="28sp" />

                    <TextView
                        android:id="@+id/achievementThreeNameText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:maxLines="2"
                        android:text="@string/achievement_name_placeholder"
                        android:textColor="@color/text_light"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Discovery radius -->

            <TextView
                android:id="@+id/discoveryRadiusTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/discovery_radius_label"
                android:textColor="@color/text_dark"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/achievementsPreviewRow" />

            <com.google.android.material.slider.Slider
                android:id="@+id/radiusSlider"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:value="15"
                android:valueFrom="1"
                android:valueTo="50"
                app:layout_constraintTop_toBottomOf="@id/discoveryRadiusTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/radiusValueText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                app:layout_constraintTop_toBottomOf="@id/radiusSlider"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="8dp" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
