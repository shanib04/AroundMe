<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.chip.Chip xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/categoryChip"
    style="@style/Widget.Material3.Chip.Filter"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginEnd="8dp"
    android:checkable="true"
    android:clickable="true"
    android:textColor="@color/map_text_dark"
    android:textStyle="bold"
    app:checkedIconVisible="false"
    app:chipBackgroundColor="@color/chip_category_background"
    app:chipCornerRadius="24dp"
    app:chipMinHeight="44dp"
    app:chipStrokeColor="@color/map_panel_stroke"
    app:chipStrokeWidth="1dp"
    app:rippleColor="@color/map_primary_soft" />

